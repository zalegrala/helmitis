{
  "chart": { "name": "demo", "version": "0.1.0" },
  "components": { "web": { "enabled": true, "workload": "Deployment" } },
  "resources": [
    {
      "file": "templates/web/deployment.yaml",
      "component": "web",
      "gvk": "apps/v1/Deployment",
